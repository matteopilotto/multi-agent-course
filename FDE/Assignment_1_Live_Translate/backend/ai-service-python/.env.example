# Python AI service config — copy to `.env`

# Provider selector: openrouter (default) | vllm  — both OpenAI-compatible
LLM_PROVIDER=openrouter

# --- openrouter (default): one API for Claude, GPT, Gemini, ... ---
OPENROUTER_API_KEY=sk-or-...
# MODEL uses OpenRouter's vendor/model slugs:
#   anthropic/claude-sonnet-4.6 | openai/gpt-5.6-terra | google/gemini-3.1-flash-lite
MODEL=anthropic/claude-sonnet-4.6

# --- vllm on RunPod (open-source model, OpenAI-compatible) ---
# LLM_PROVIDER=vllm
# VLLM_BASE_URL=https://<pod-id>-8000.proxy.runpod.net/v1
# VLLM_API_KEY=EMPTY
# MODEL=<the model id vLLM is serving, e.g. Qwen/Qwen2.5-7B-Instruct>

TRANSLATION_DB_PATH=translations.db
BATCH_CONCURRENCY=8   # max simultaneous LLM calls within /translate/batch
