# Python AI service config — copy to `.env`

# Provider selector: openrouter (default) | vllm  — both OpenAI-compatible
LLM_PROVIDER=openrouter

# --- openrouter (default): one API for Claude, GPT, Gemini, ... ---
OPENROUTER_API_KEY=sk-or-...
# MODEL uses OpenRouter's vendor/model slugs:
#   anthropic/claude-sonnet-4.6 | openai/gpt-5.6-terra | google/gemini-3.1-flash-lite
MODEL=anthropic/claude-sonnet-4.6

# --- vllm on RunPod (open-source model, OpenAI-compatible) ---
# LLM_PROVIDER=vllm
# VLLM_BASE_URL=https://<pod-id>-8000.proxy.runpod.net/v1
# VLLM_API_KEY=EMPTY
# MODEL=<the model id vLLM is serving, e.g. Qwen/Qwen2.5-7B-Instruct>

TRANSLATION_DB_PATH=translations.db
BATCH_CONCURRENCY=8   # max simultaneous LLM calls within /translate/batch

# --- persistent cache tier (L2) ---
# sqlite (default): local file at TRANSLATION_DB_PATH, survives restart on one machine.
# redis: shared + persistent across machines (e.g. Upstash), for multi-region.
CACHE_BACKEND=sqlite
# REDIS_URL=rediss://default:<password>@<host>:<port>   # required when CACHE_BACKEND=redis
# CACHE_TTL_SECONDS=                                     # optional Redis key expiry; blank = no expiry
# NOTE: /stats hit-rate counters stay per-process (per-machine); only cache *content* is shared via Redis.
